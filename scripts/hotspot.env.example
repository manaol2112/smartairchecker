# The ./setuphotspot command copies this to .hotspot.env the first time, then runs setup.
# Or copy yourself and run:  sudo -E ./scripts/setup-wifi-ap.sh
# (sudo loads root env — use: sudo --preserve-env=SMARTAIR_AP_SSID,SMARTAIR_AP_PASS,… if needed)
#
# Wi-Fi name and password (hotspot)
# Use a password 8+ characters, OR set SMARTAIR_AP_OPEN=1 (also yes|true) for no password.
# (anyone in range can join — good for demos; not for private data).
# If you set OPEN, you can leave SMARTAIR_AP_PASS as below (ignored for encryption).
# After changing, always re-run: ./setuphotspot
# Avoid spaces in the password and forget the old Wi-Fi on the phone when switching open ↔ WPA2.
SMARTAIR_AP_SSID=SmartAirDemo
SMARTAIR_AP_PASS=sciencefair8
# --- No password (for demos: classic stack + no captive = fewest "stuck connecting" issues) ---
# SMARTAIR_AP_OPEN=1
# HOTSPOT_USE_CLASSIC=1
# HOTSPOT_CAPTIVE=0

# Auto-redirect / “captive” (DNS on Pi :53 + :80 to Flask) — if phones hang on "Connecting", try
# HOTSPOT_CAPTIVE=0 first. See docs/pi-wifi-hotspot.md
# HOTSPOT_CAPTIVE=1
# If dnsmasq will not start or phones get no IP, try:  HOTSPOT_DNSMASQ_BIND_DYNAMIC=1
# If setup hangs in "hostapd -t" (rare; Pi Wi-Fi driver):  HOTSPOT_HOSTAPD_TEST_SEC=1
# Captive: default = selective DNS to the Pi (not every hostname) — if the Pi freezes with many
# phones, do NOT set the line below. Only for debugging / legacy:
# HOTSPOT_CAPTIVE_WILDCARD=1

# ISO country code (hostapd uses this; required for legal channels and tx power on Pi)
WIFI_COUNTRY=US

# 2.4 GHz only (1, 6, 11 are common; 1 is a good default for compatibility)
# AP_CHANNEL=1

# Wi-Fi interface to use (usually wlan0; use iw dev if unsure)
AP_IFACE=wlan0

# Port your Flask app listens on (config.yaml server.port or SMARTAIR_PORT)
# For demo, 5001 needs no root; use 80 only if you know how to bind (see docs)
SMARTAIR_PORT=5001

# After setup, IP is often 10.42.0.1 (NetworkManager) or 192.168.4.1 (hostapd path),
# and is written to .hotspot.state. Run: ./scripts/generate-demo-qrs.sh --detect
# Full guide: docs/pi-wifi-hotspot.md
#
# If nmcli "succeeds" but phones never see the SSID (iw does not show type ap), the setup
# script falls back to hostapd automatically. Set HOTSPOT_NM_STRICT=1 only if you must
# keep the NetworkManager path despite that (not recommended for demos).
# HOTSPOT_NM_STRICT=0
