{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "smartairchecker: this computer (no Pi hardware)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "SMARTAIR_LAPTOP": "1"
      }
    },
    {
      "name": "smartairchecker: Raspberry Pi (real sensor + lights)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
